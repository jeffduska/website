<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>duska.com</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      background: #0a0a0a;
      color: #e0e0e0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      text-align: center;
    }
    main {
      max-width: 560px;
      padding: 2rem;
    }
    h1 {
      font-size: 3rem;
      font-weight: 200;
      letter-spacing: -0.02em;
      margin: 0 0 0.5rem;
    }
    p {
      color: #888;
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .accent { color: #6cb6ff; }
  </style>
</head>
<body>
  <main>
    <h1>duska<span class="accent">.</span>com</h1>
    <p>A placeholder. Something more interesting will appear here eventually.</p>
  </main>
</body>
</html>